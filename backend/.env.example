# Banco de Dados
DATABASE_URL=postgresql+asyncpg://sgal_user:sgal_pass@localhost:5432/sgal_db

# Provedor de IA: "anthropic" ou "openai"
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Thresholds de alerta (dias)
ALERT_YELLOW_DAYS=60
ALERT_RED_DAYS=15

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# Debug
DEBUG=false
